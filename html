            </div>
        </div>

        <footer class="mt-8 text-center no-print">
            <button onclick="window.print()" class="bg-indigo-600 hover:bg-indigo-500 text-white px-8 py-3 rounded-full font-bold transition flex items-center gap-2 mx-auto shadow-lg shadow-indigo-500/20">
                <i class="fa-solid fa-download"></i> Télécharger le CV (PDF)
            </button>
            <p class="mt-6 text-slate-500 text-xs uppercase tracking-widest">© 2026 Asmaa Lahlou — Propulsé par Tailwind CSS</p>
        </footer>
    </div>

</body>
</html>
